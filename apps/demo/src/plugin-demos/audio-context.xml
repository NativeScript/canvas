<Page xmlns="http://schemas.nativescript.org/tns.xsd" xmlns:canvas="@nativescript/canvas" navigatingTo="navigatingTo" class="page audio-page">
  <Page.actionBar>
    <ActionBar title="Audio — WebAudio Demo" class="action-bar" />
  </Page.actionBar>

  <GridLayout androidOverflowEdge="none" rows="auto,220,auto,auto" class="p-12">
    <StackLayout row="0" orientation="horizontal" spacing="10" class="top-controls">
      <Button text="Play Sample" tap="playSample" class="btn btn-primary" />
      <Button text="Stop" tap="stopTap" class="btn btn-secondary" />
    </StackLayout>
    <canvas:Canvas id="visualizer" row="1" ready="canvasReady"  style="width:100%; height:100%;" />

    <StackLayout row="2" padding="8">
      <Label text="Volume" class="muted" />
      <Slider minValue="0" maxValue="100" value="80" valueChange="onVolumeChange" />
    </StackLayout>

    <StackLayout row="3" padding="8">
      <Label text="Realtime graphic EQ is disabled, visualizer only." class="muted" />
    </StackLayout>
  </GridLayout>
</Page>