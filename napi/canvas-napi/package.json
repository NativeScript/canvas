{
	"name": "@nativescript/canvas-napi",
	"version": "0.0.7",
	"main": "index.cjs",
	"module": "index.mjs",
	"types": "index.d.ts",
	"type": "module",
	"exports": {
		".": {
			"import": "./index.mjs",
			"require": "./index.cjs"
		}
	},
	"napi": {
		"name": "canvas-napi",
		"triples": {
			"defaults": false,
			"additional": [
				"aarch64-apple-darwin",
				"x86_64-apple-darwin",
				"universal-apple-darwin"
			]
		}
	},
	"license": "MIT",
	"dependencies": {
		"@nativescript/foundation": "0.0.1-alpha.22",
		"@nativescript/macos-node-api": "0.1.4",
		"yoga-layout": "3.1.0"
	},
	"devDependencies": {
		"@napi-rs/cli": "^2.18.4",
		"@rollup/plugin-commonjs": "^28.0.2",
		"@rollup/plugin-typescript": "^12.1.2",
		"@tsconfig/node22": "^22.0.0",
		"@types/node": "^22.9.0",
		"ava": "^6.0.1",
		"rollup": "^4.28.1",
		"rollup-plugin-dts": "^6.1.1",
		"rollup-plugin-copy": "3.5.0",
		"typescript": "^5.6.3"
	},
	"ava": {
		"timeout": "3m"
	},
	"engines": {
		"node": ">=22.6.0"
	},
	"scripts": {
		"artifacts": "napi artifacts",
		"build": "napi build --platform --release --js js-bindings.js",
		"build:osx:x86": "napi build --platform --target x86_64-apple-darwin --release --js js-bindings.js",
		"build:osx:arm64": "napi build --platform --target aarch64-apple-darwin --release --js js-bindings.js",
		"build:osx:universal": "npm run build:osx:x86 && npm run build:osx:arm64 && napi universal -d ./",
		"build:debug": "napi build --platform --js js-bindings.js",
		"build:npm": "rollup -c ./config/rollup.config.js",
		"prepublishOnly": "napi prepublish -t npm",
		"test": "ava",
		"universal": "napi universal",
		"version": "napi version",
		"start-node": "cd examples/node && npm run start",
		"debug-node": "cd examples/node && npm run debug",
		"start-deno": "deno run -A deno.ts"
	},
	"optionalDependencies": {
		"@nativescript/canvas-napi-darwin-arm64": "0.0.7",
		"@nativescript/canvas-napi-darwin-x64": "0.0.7",
		"@nativescript/canvas-napi-darwin-universal": "0.0.7"
	}
}
