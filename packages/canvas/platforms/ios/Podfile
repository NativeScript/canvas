platform :ios, '12.0'

# The NativeScript V8 headers package is now provided via SPM (the `NativeScriptV8` product of
# the local `nativescript-v8` Swift package) instead of a `pod 'NativeScript'`. CocoaPods is still
# needed here only for this post_install: the canvas C++ includes <NativeScript/include/v8.h>, and
# the V8 headers include each other by bare name (e.g. #include "v8config.h"), so the built runtime
# framework's v8 include root must be on HEADER_SEARCH_PATHS. We append with `<<` (not via an
# xcconfig) because the NativeScript plugin-xcconfig merge is first-key-wins and would otherwise
# clobber (or be clobbered by) the pod-injected HEADER_SEARCH_PATHS. Without this the build fails
# with "'v8config.h' file not found".
post_install do |installer|
  installer.aggregate_targets.each do |aggregate_target|
    aggregate_target.user_targets.each do |target|
      target.build_configurations.each do |config|
        config.build_settings['HEADER_SEARCH_PATHS'] ||= ['$(inherited)']

        config.build_settings['HEADER_SEARCH_PATHS'] << \
          '$(BUILD_DIR)/$(CONFIGURATION)$(EFFECTIVE_PLATFORM_NAME)/NativeScript.framework/Headers'

        config.build_settings['HEADER_SEARCH_PATHS'] << \
          '$(BUILD_DIR)/$(CONFIGURATION)$(EFFECTIVE_PLATFORM_NAME)/NativeScript.framework/Headers/include'
      end
    end
  end
end
